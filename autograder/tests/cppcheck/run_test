#!/usr/bin/env bash
set -eo pipefail

TIMEOUT=30
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TESTS_DIR="$(dirname "$SCRIPT_DIR")"
AUTOGRADER_DIR="$(dirname "$TESTS_DIR")"
PROJECT_ROOT="$(dirname "$AUTOGRADER_DIR")"
SUBMISSION_DIR="/autograder/submission"
ROOT_DIR="${AUTOGRADER_DIR}"
INCLUDE_DIR="${TESTS_DIR}/include"
SRC_DIR="${TESTS_DIR}/src"
HEADER_DIR="${INCLUDE_DIR}"
LOG_FILE="${SCRIPT_DIR}/cppcheck.log"
SUPPRESSIONS_FILE="${SCRIPT_DIR}/suppressions.txt"

: > "$LOG_FILE"

log() {
    echo "$@" | tee -a "$LOG_FILE"
}

if ! command -v cppcheck >/dev/null 2>&1; then
    log "Error: cppcheck no esta instalado"
    exit 1
fi

if [[ -d "${SUBMISSION_DIR}/src" ]]; then
    SRC_DIR="${SUBMISSION_DIR}/src"
elif [[ -d "${PROJECT_ROOT}/src" ]]; then
    SRC_DIR="${PROJECT_ROOT}/src"
elif [[ -d "${AUTOGRADER_DIR}/src" ]]; then
    SRC_DIR="${AUTOGRADER_DIR}/src"
fi

if [[ -d "${SUBMISSION_DIR}/include" ]]; then
    HEADER_DIR="${SUBMISSION_DIR}/include"
elif [[ -d "${PROJECT_ROOT}/include" ]]; then
    HEADER_DIR="${PROJECT_ROOT}/include"
elif [[ -d "${AUTOGRADER_DIR}/include" ]]; then
    HEADER_DIR="${AUTOGRADER_DIR}/include"
fi

EIGEN_DIR=""
if [[ -d "${ROOT_DIR}/third_party/eigen-3.4.0" ]]; then
    EIGEN_DIR="${ROOT_DIR}/third_party/eigen-3.4.0"
elif [[ -d "/usr/include/eigen3" ]]; then
    EIGEN_DIR="/usr/include/eigen3"
fi

CPPCHECK_INCLUDE_FLAGS=(
    -I"${TESTS_DIR}"
    -I"${INCLUDE_DIR}"
    -I"${HEADER_DIR}"
    -I"${SRC_DIR}"
    -I"${SUBMISSION_DIR}"
    -I"${SUBMISSION_DIR}/include"
)
if [[ -n "$EIGEN_DIR" ]]; then
    CPPCHECK_INCLUDE_FLAGS+=(-I"${EIGEN_DIR}")
fi

CPPCHECK_IGNORE_FLAGS=()
if [[ -n "$EIGEN_DIR" ]]; then
    CPPCHECK_IGNORE_FLAGS+=(-i"${EIGEN_DIR}")
fi

CPP_STD_ARG=()
for candidate in c++23 c++20 c++17 c++14 c++11 c++03; do
    if cppcheck \
        --enable=information \
        --std="${candidate}" \
        --language=c++ \
        "${CPPCHECK_IGNORE_FLAGS[@]}" \
        "${CPPCHECK_INCLUDE_FLAGS[@]}" \
        "${SCRIPT_DIR}/cppcheck.cpp" >/dev/null 2>&1; then
        CPP_STD_ARG=(--std="${candidate}")
        break
    fi
done

FILES=(
    "${SCRIPT_DIR}/cppcheck.cpp"
    "${HEADER_DIR}/utec/algebra/shape.h"
    "${HEADER_DIR}/utec/nn/nn_interfaces.h"
    "${HEADER_DIR}/utec/nn/nn_activation.h"
    "${HEADER_DIR}/utec/nn/nn_optimizer.h"
    "${HEADER_DIR}/utec/nn/nn_dense.h"
    "${HEADER_DIR}/utec/nn/nn_convolution.h"
    "${HEADER_DIR}/utec/nn/nn_pooling.h"
    "${HEADER_DIR}/utec/nn/nn_flatten.h"
    "${HEADER_DIR}/utec/nn/nn_graph.h"
    "${HEADER_DIR}/utec/nn/neural_network.h"
)

for fullpath in "${FILES[@]}"; do
    if [[ ! -f "$fullpath" ]]; then
        log "Warning: archivo no encontrado - $fullpath"
        gzip -f "$LOG_FILE"
        exit 1
    fi
done

log "Analizando proyecto con cppcheck..."

if ! timeout "$TIMEOUT" cppcheck \
    --enable=warning,style,performance,portability,information \
    "${CPP_STD_ARG[@]}" \
    --language=c++ \
    --inline-suppr \
    --suppressions-list="$SUPPRESSIONS_FILE" \
    --template='{id}|{severity}|{file}|{line}|{message}' \
    "${CPPCHECK_IGNORE_FLAGS[@]}" \
    "${CPPCHECK_INCLUDE_FLAGS[@]}" \
    "${FILES[@]}" 2>&1 | tee -a "$LOG_FILE"; then
    if [[ "${PIPESTATUS[0]}" -eq 124 ]]; then
        log "Timeout excedido durante el analisis con cppcheck"
    else
        log "Cppcheck no pudo completar el analisis"
    fi
    gzip -f "$LOG_FILE"
    exit 1
fi

if grep -Eq '^[^|]+\|(error|warning|portability)\|' "$LOG_FILE"; then
    log "Cppcheck: se encontraron problemas relevantes"
    gzip -f "$LOG_FILE"
    exit 1
fi

if grep -Eq '^[^|]+\|(style|performance|information)\|' "$LOG_FILE"; then
    log "Cppcheck: solo se encontraron observaciones informativas de estilo/rendimiento"
else
    log "Cppcheck: todos los checks pasaron"
fi

gzip -f "$LOG_FILE"

exit 0
